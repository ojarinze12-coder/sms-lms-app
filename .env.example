# ===========================================
# Vercel Deployment Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values

# ===========================================
# DATABASE
# ===========================================
# Use Supabase connection pooler for Vercel serverless
DATABASE_URL="postgresql://[user]:[password]@aws-0-[region].pooler.supabase.com:6543/[dbname]?pgbouncer=true"

# Direct URL for Prisma migrations (not used by app)
DIRECT_URL="postgresql://[user]:[password]@aws-0-[region].pooler.supabase.com:5432/[dbname]"

# ===========================================
# AUTHENTICATION
# ===========================================
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-auth-secret-key-min-32-chars"

# ===========================================
# PAYMENT GATEWAYS
# ===========================================
# Flutterwave
FLUTTERWAVE_PUBLIC_KEY="FLWPUBK-xxxxxxxxxxxxxxxxxxxxxxxx"
FLUTTERWAVE_SECRET_KEY="FLWSECK-xxxxxxxxxxxxxxxxxxxxxxxx"
FLUTTERWAVE_WEBHOOK_SECRET="xxxxxxxxxxxxxxxxxxxxxxxx"

# Paystack
PAYSTACK_SECRET_KEY="sk_live_xxxxxxxxxxxxxxxxxxxxxxxx"
PAYSTACK_PUBLIC_KEY="pk_live_xxxxxxxxxxxxxxxxxxxxxxxx"
PAYSTACK_WEBHOOK_SECRET="xxxxxxxxxxxxxxxxxxxxxxxx"

# Remita
REMITA_MERCHANT_ID="xxxxxxxxxx"
REMITA_API_KEY="xxxxxxxxxx"
REMITA_SERVICE_TYPE_ID="xxxxxx"

# ===========================================
# EMAIL / SMTP
# ===========================================
SMTP_HOST="smtp.mailtrap.io"
SMTP_PORT="2525"
SMTP_USER="xxxxxxxxxxxxxxxx"
SMTP_PASS="xxxxxxxxxxxxxxxx"
SMTP_FROM_EMAIL="noreply@yourdomain.com"
SMTP_FROM_NAME="School Management System"

# ===========================================
# AI / OPENROUTER
# ===========================================
# Get from https://openrouter.ai
OPENROUTER_API_KEY="sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxx"
OPENROUTER_MODEL="openrouter/free:latest"

# ===========================================
# FILE STORAGE
# ===========================================
# Supabase Storage (if using Supabase for file uploads)
NEXT_PUBLIC_SUPABASE_URL="https://xxxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="xxxxxxxxxxxxxxxxxxxxxxxx"

# ===========================================
# APPLICATION
# ===========================================
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="School Management System"

# ===========================================
# FEATURE FLAGS
# ===========================================
ENABLE_AI_FEATURES="true"
ENABLE_PAYMENT_FEATURES="true"
