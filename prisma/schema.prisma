enum BroadcastType {
  SYSTEM
  ANNOUNCEMENT
  MAINTENANCE
  FEATURE
  MARKETING
  URGENT
}

enum BroadcastScope {
  ALL
  ALL_ADMINS
  SPECIFIC_PLANS
  SPECIFIC_TENANTS
}

