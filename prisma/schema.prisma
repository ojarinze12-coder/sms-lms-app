// ==================== LMS: Exams ====================
enum ExamType {
  QUIZ
  MID_TERM
  END_TERM
  ASSIGNMENT
  PRACTICE
  // Nigerian External Exams
  WAEC
  NECO
  BECE
  JAMB_UTME
  MOCK
}

model Exam {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String
  description String?
  examType    ExamType  @default(MID_TERM)
  status      String?   @default("DRAFT")
  duration    Int?      @default(60)
  startTime   DateTime? @db.Timestamptz(6)
  endTime     DateTime? @db.Timestamptz(6)
  termId      String?   @db.Uuid
  subjectId   String?   @db.Uuid
  createdById String?   @db.Uuid
  tenantId    String?   @db.Uuid
  createdAt   DateTime? @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime? @default(now()) @updatedAt @db.Timestamptz(6)

  term      Term?      @relation(fields: [termId], references: [id])
  subject   Subject?   @relation(fields: [subjectId], references: [id])
  questions Question[]
  results   Result[]

  @@index([subjectId], map: "idx_exams_subject")
  @@index([termId], map: "idx_exams_term")
  @@map("exams")
}

model Question {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  content   String
  type      String?   @default("MULTIPLE_CHOICE")
  points    Int?      @default(1)
  order     Int?
  examId    String?   @db.Uuid
  createdAt DateTime? @default(now()) @db.Timestamptz(6)
  updatedAt DateTime? @default(now()) @updatedAt @db.Timestamptz(6)

  exam    Exam?    @relation(fields: [examId], references: [id], onDelete: Cascade)
  options Option[]

  @@index([examId], map: "idx_questions_exam")
  @@map("questions")
}

model Option {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  content    String
  isCorrect  Boolean?  @default(false)
  order      Int?
  questionId String?   @db.Uuid
  createdAt  DateTime? @default(now()) @db.Timestamptz(6)
  updatedAt  DateTime? @default(now()) @updatedAt @db.Timestamptz(6)

  question Question? @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId], map: "idx_options_question")
  @@map("options")
}

model Result {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  score       Float?
  percentage  Float?
  status      String?   @default("PENDING")
  startedAt   DateTime? @db.Timestamptz(6)
  submittedAt DateTime? @db.Timestamptz(6)
  gradedAt    DateTime? @db.Timestamptz(6)
  examId      String?   @db.Uuid
  studentId   String?   @db.Uuid
  createdAt   DateTime? @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime? @default(now()) @updatedAt @db.Timestamptz(6)

  exam    Exam?           @relation(fields: [examId], references: [id])
  student Student?        @relation(fields: [studentId], references: [id])
  answers StudentAnswer[]

  @@unique([examId, studentId], map: "results_examId_studentId_unique")
  @@index([examId], map: "idx_results_exam")
  @@index([studentId], map: "idx_results_student")
  @@map("results")
}

model StudentAnswer {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  resultId   String?   @db.Uuid
  questionId String?   @db.Uuid
  optionId   String?   @db.Uuid
  textAnswer String?
  isCorrect  Boolean?
  points     Float?
  createdAt  DateTime? @default(now()) @db.Timestamptz(6)
  updatedAt  DateTime? @default(now()) @updatedAt @db.Timestamptz(6)

  result Result? @relation(fields: [resultId], references: [id], onDelete: Cascade)

  @@unique([resultId, questionId], map: "student_answers_resultId_questionId_unique")
  @@map("student_answers")
}

// ==================== SMS: Grading Scale ====================
model GradingScale {
