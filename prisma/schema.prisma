// ==================== SMS: FEE MANAGEMENT (Nigeria) ====================
model FeeStructure {
  id             String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String
  description    String?
  amount         Float
  type           FeeType
  category       FeeCategory @default(MANDATORY)
  isRecurring    Boolean     @default(false)
  installments   Int?        @default(1)
  dueDate        DateTime?   @db.Date
  academicYearId String      @db.Uuid
  termId         String?     @db.Uuid
  tenantId       String      @db.Uuid
  createdAt      DateTime    @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime    @default(now()) @updatedAt @db.Timestamptz(6)

  academicYear AcademicYear @relation(fields: [academicYearId], references: [id])
  term         Term?        @relation(fields: [termId], references: [id])
  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  payments     FeePayment[]

  @@index([academicYearId], map: "idx_fee_structures_academic_year")
  @@index([tenantId], map: "idx_fee_structures_tenant")
  @@map("fee_structures")
}

enum FeeType {
  TUITION
  REGISTRATION
  EXAM
  TRANSPORT
  HOSTEL
  LIBRARY
  UNIFORM
  EXTRA_CURRICULAR
  LEVY
  BOOK
  PTA
  OTHER
}

enum FeeCategory {
  MANDATORY
  OPTIONAL
  INSTALLMENT
}

model FeePayment {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  amount          Float
  method          PaymentMethod
  status          PaymentStatus @default(PENDING)
  referenceNo     String?
  transactionId   String? // Paystack/Flutterwave transaction ID
  paymentGateway  String? // PAYSTACK, FLUTTERWAVE, CASH, BANK
  gatewayResponse Json? // Full gateway response
  paidAt          DateTime?     @db.Timestamptz(6)
  receiptUrl      String?
  notes           String?
  studentId       String        @db.Uuid
  feeId           String        @db.Uuid
  tenantId        String        @db.Uuid
  createdAt       DateTime      @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime      @default(now()) @updatedAt @db.Timestamptz(6)

  student      Student      @relation(fields: [studentId], references: [id])
  feeStructure FeeStructure @relation(fields: [feeId], references: [id])
  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, referenceNo], map: "fee_payments_tenantId_referenceNo_unique")
  @@index([studentId], map: "idx_fee_payments_student")
  @@index([feeId], map: "idx_fee_payments_fee")
  @@index([transactionId], map: "idx_fee_payments_transaction")
  @@map("fee_payments")
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CARD
  ONLINE
  USSD
  CHEQUE
  WAIVER
  POS
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
  CANCELLED
}

