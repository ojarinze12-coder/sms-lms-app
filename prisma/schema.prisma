  updatedAt   DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  route  TransportRoute? @relation(fields: [routeId], references: [id])
  tenant Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, vehicleNo], map: "transport_vehicles_tenantId_vehicleNo_unique")
  @@map("transport_vehicles")
}

// ==================== LMS: Gamification ====================
model Badge {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  description String?
  icon        String?
  criteria    Json? // { type: 'completion', value: 100, tiers: ['SSS', 'PRI'] }
  points      Int      @default(0)
  isGlobal    Boolean  @default(true) // true = applies to all tiers, false = tier-specific
  tierId      String?   @db.Uuid // NULL = global, specific tier = tier-specific
  tenantId    String?   @db.Uuid
  createdAt   DateTime @default(now()) @db.Timestamptz(6)

  tier     Tier?         @relation(fields: [tierId], references: [id])
  tenant   Tenant?       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  students StudentBadge[]

  @@index([tenantId], map: "idx_badges_tenant")
  @@index([tierId], map: "idx_badges_tier")
  @@map("badges")
}

model StudentBadge {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studentId String    @db.Uuid
  badgeId   String    @db.Uuid
  tierLevel Int?      // Level number when badge was earned (e.g., 15 for SSS3)
  tierName  String?   // Tier name when badge was earned (e.g., "SSS 3")
  earnedAt  DateTime  @default(now())
  awardedBy String?   @db.Uuid // User who awarded (for manual awards)
  isAuto    Boolean   @default(true) // true = auto-awarded, false = manually awarded

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  badge   Badge   @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([studentId, badgeId], map: "student_badges_unique")
  @@index([studentId], map: "idx_student_badges_student")
  @@index([badgeId], map: "idx_student_badges_badge")
  @@map("student_badges")
}

model Certificate {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String
  description String?
  template    String?
  courseId    String?  @db.Uuid
  criteria    Json? // { type: 'min_score', value: 75 }
  createdAt   DateTime @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  StudentCertificate StudentCertificate[]

  @@map("certificates")
}

model StudentCertificate {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studentId     String   @db.Uuid
  certificateId String   @db.Uuid
  issuedAt      DateTime @default(now()) @db.Timestamptz(6)
  pdfUrl        String?

  student     Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  certificate Certificate @relation(fields: [certificateId], references: [id], onDelete: Cascade)

  @@unique([studentId, certificateId], map: "student_certificates_unique")
  @@map("student_certificates")
}

