generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==================== TENANT ====================
model Tenant {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid 
  name       String
  slug       String   @unique
  domain     String?
  plan       String   @default("FREE")
  status     String   @default("ACTIVE")
  brandColor String   @default("#1a56db")
  logo       String?
  createdAt  DateTime @default(now()) @db.Timestamptz(6)
  updatedAt  DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  users               User[]
  students            Student[]
  teachers            Teacher[]
  courses             Course[]
  classes             Class[]
  enrollments         Enrollment[]
  invoices            Invoice[]
  academicYears       AcademicYear[]
  subscriptions       Subscription[]
  subscriptionInvoices SubscriptionInvoice[]
  parents             Parent[]
  auditLogs           AuditLog[]
  feeStructures       FeeStructure[]
  feePayments         FeePayment[]
  staffLeaves         StaffLeave[]
  staff               Staff[]
  parentStudents      ParentStudent[]
  announcements       Announcement[]
  libraryBooks        LibraryBook[]
  libraryCirculations LibraryCirculation[]
  transportRoutes     TransportRoute[]
  transportVehicles   TransportVehicle[]
  transportStops      TransportStop[]
  Payroll             Payroll[]
  Application         Application[]

  tenantConfig     TenantConfig?
  onboardingTasks  OnboardingTask[]
  tenantResources  TenantResource?
  tenantHealth     TenantHealth?
  supportTickets   SupportTicket[]
  modules          TenantModule[]
  siblingDiscounts SiblingDiscount[]
  
  tiers           Tier[]
  departments      Department[]
  tenantSettings   TenantSettings?
  tierCurriculum  TierCurriculum[]
  badges          Badge[]

  @@map("tenants")
}

enum Plan {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

// ==================== AUTH ====================
model User {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) 
  email     String   @unique
  password  String?
  firstName String?
  lastName  String?
  role      UserRole @default(TEACHER)
  tenantId  String?   
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  tenant Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  Parent Parent[]

  @@index([tenantId], map: "idx_users_tenant")
  @@map("users")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  PRINCIPAL
  VICE_PRINCIPAL
  ACADEMIC_ADMIN
  FINANCE_ADMIN
  BURSAR
  TEACHER
  STUDENT
  PARENT
}

// ==================== SMS: Students ====================
model Student {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studentId   String // Internal school ID
  email       String?
  firstName   String
  lastName    String
  middleName  String?
  dateOfBirth DateTime? @db.Date
  gender      Gender?
  phone       String?
  address     String?

  // Nigerian-specific fields
  stateOfOrigin     String? // State
  lgaOfOrigin       String? // LGA
  birthCertNo       String? // Birth Certificate Number
  jambRegNo         String? // JAMB Registration Number (for SS3)
  bloodGroup        String?
  genotype          String?
  allergies         String?
  medicalConditions String?
  emergencyContact  String?
  emergencyPhone    String?

  // Profile
  photo  String?
  status StudentStatus @default(ACTIVE)

  tenantId  String   @db.Uuid
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  tenant              Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  enrollments         Enrollment[]
  parents             Parent[]
  parentStudents      ParentStudent[]
  attendances         Attendance[]
  feePayments         FeePayment[]
  libraryCirculations LibraryCirculation[]
  studentBadges       StudentBadge[]
  studentCertificates StudentCertificate[]
  results             Result[]

  @@unique([tenantId, studentId], map: "students_tenantId_studentId_unique")
  @@index([tenantId], map: "idx_students_tenant")
  @@index([stateOfOrigin], map: "idx_students_state")
  @@map("students")
}

enum StudentStatus {
  ACTIVE
  INACTIVE
  GRADUATED
  TRANSFERRED
  SUSPENDED
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

// ==================== SMS: Teaching Staff (Teachers) ====================
model Teacher {
  id         String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId String
  email      String
  firstName  String
  lastName   String
  specialty  String?
  phone      String?

  // Nigerian HR fields
  dateOfBirth   DateTime? @db.Date
  gender        String?
  address       String?
  stateOfOrigin String?
  lgaOfOrigin   String?

  // Employment details
  qualification  String?
  experience     Int?
  joinDate       DateTime? @db.Date
  employmentType String? // FULL_TIME, PART_TIME, CONTRACT
  department     String?
  position       String?
  salary         Float?

  // Nigerian compliance
  pensionPin   String? // Pension PIN
  nhfNumber    String? // NHF Number
  bvn          String? // Bank Verification Number
  bankName     String?
  bankAccount  String?
  bankSortCode String?

  // Status
  status String @default("ACTIVE") // ACTIVE, INACTIVE, ON_LEAVE, TERMINATED

  tenantId  String   @db.Uuid
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subjects    Subject[]
  staffLeaves StaffLeave[]
  payrolls    Payroll[]

  @@unique([tenantId, employeeId], map: "teachers_tenantId_employeeId_unique")
  @@index([tenantId], map: "idx_teachers_tenant")
  @@map("teachers")
}

// ==================== SMS: Non-Teaching Staff ====================
enum StaffCategory {
  ADMINISTRATIVE
  BURSAR
  LIBRARIAN
  SECURITY
  CLEANER
  DRIVER
  COOK
  MAINTENANCE
  IT_SUPPORT
  COUNSELOR
  NURSE
  OTHER
}

enum StaffEmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  CASUAL
}

model Staff {
  id         String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId String
  email      String
  firstName  String
  lastName   String
  category   StaffCategory @default(OTHER)
  phone      String?

  // Personal details
  dateOfBirth   DateTime? @db.Date
  gender        String?
  address       String?
  stateOfOrigin String?
  lgaOfOrigin   String?
  photo         String?

  // Employment details
  qualification  String?
  experience     Int?
  joinDate       DateTime?           @db.Date
  employmentType StaffEmploymentType @default(FULL_TIME)
  department     String?
  position       String?
  salary         Float?

  // Nigerian compliance
  pensionPin   String?
  nhfNumber    String?
  bvn          String?
  bankName     String?
  bankAccount  String?
  bankSortCode String?

  // Status
  status String @default("ACTIVE") // ACTIVE, INACTIVE, ON_LEAVE, TERMINATED

  tenantId  String   @db.Uuid
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  staffLeaves StaffLeave[]

  @@unique([tenantId, employeeId], map: "staff_tenantId_employeeId_unique")
  @@index([tenantId], map: "idx_staff_tenant")
  @@index([tenantId, category], map: "idx_staff_category")
  @@map("staff")
}

// ==================== SMS: Payroll ====================
model Payroll {
  id    String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  month Int // 1-12
  year  Int

  // Salary components
  basicSalary        Float
  housingAllowance   Float?
  transportAllowance Float?
  otherAllowances    Float?
  totalEarnings      Float?

  // Deductions
  pensionDeduction Float?
  taxDeduction     Float?
  nhfDeduction     Float?
  otherDeductions  Float?
  totalDeductions  Float?

  // Net pay
  netPay Float?

  // Status
  status           String    @default("DRAFT") // DRAFT, PROCESSED, APPROVED, PAID
  paymentDate      DateTime? @db.Timestamptz(6)
  paymentReference String?

  teacherId String   @db.Uuid
  tenantId  String   @db.Uuid
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  teacher Teacher @relation(fields: [teacherId], references: [id])
  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([teacherId, month, year], map: "payroll_teacher_month_year_unique")
  @@index([tenantId, year, month], map: "payroll_tenant_year_month")
  @@map("payrolls")
}

// ==================== SMS: Parents ====================
enum ParentRelationship {
  FATHER
  MOTHER
  GUARDIAN
  OTHER
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum LinkingMode {
  AUTO_APPROVE
  ADMIN_APPROVAL
  HYBRID
}

model Parent {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  firstName        String
  lastName         String
  email            String?
  phone            String?
  occupation       String?
  workplace        String?
  relationship     ParentRelationship @default(GUARDIAN)
  isPrimaryContact Boolean            @default(false)
  approvalStatus   ApprovalStatus     @default(PENDING)
  tenantId         String?            @db.Uuid
  userId           String?            @db.Uuid
  createdAt        DateTime?          @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime?          @default(now()) @updatedAt @db.Timestamptz(6)

  tenant         Tenant?         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user           User?           @relation(fields: [userId], references: [id])
  parentStudents ParentStudent[]
  Student        Student?        @relation(fields: [studentId], references: [id])
  studentId      String?         @db.Uuid

  @@map("parents")
}

// Junction table: Parent-Student (supports multiple children)
model ParentStudent {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  parentId         String             @db.Uuid
  studentId        String             @db.Uuid
  relationship     ParentRelationship @default(GUARDIAN)
  isPrimaryContact Boolean            @default(false)
  approvalStatus   ApprovalStatus     @default(PENDING)
  approvedBy       String?            @db.Uuid
  approvedAt       DateTime?          @db.Timestamptz(6)
  createdAt        DateTime?          @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime?          @default(now()) @updatedAt @db.Timestamptz(6)

  parent   Parent  @relation(fields: [parentId], references: [id], onDelete: Cascade)
  student  Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  Tenant   Tenant? @relation(fields: [tenantId], references: [id])
  tenantId String? @db.Uuid

  @@unique([parentId, studentId], map: "parent_student_unique")
  @@index([parentId], map: "idx_parent_student_parent")
  @@index([studentId], map: "idx_parent_student_student")
  @@map("parent_students")
}

// Sibling Discount Configuration
model SiblingDiscount {
  id                  String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId            String      @db.Uuid
  academicYearId      String?     @db.Uuid
  linkingMode         LinkingMode @default(ADMIN_APPROVAL)
  discountType        String      @default("PERCENTAGE") // PERCENTAGE, FIXED
  secondChildDiscount Float       @default(0) // e.g., 10 for 10%
  thirdChildDiscount  Float       @default(0)
  fourthChildDiscount Float       @default(0)
  fifthChildDiscount  Float       @default(0)
  isActive            Boolean     @default(true)
  createdAt           DateTime    @default(now()) @db.Timestamptz(6)
  updatedAt           DateTime    @default(now()) @updatedAt @db.Timestamptz(6)

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  academicYear AcademicYear? @relation(fields: [academicYearId], references: [id])

  @@unique([tenantId, academicYearId], map: "sibling_discount_unique")
  @@map("sibling_discounts")
}

// ==================== SMS: Academic Structure ====================
model AcademicYear {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  startDate DateTime  @db.Timestamptz(6)
  endDate   DateTime  @db.Timestamptz(6)
  isActive  Boolean?  @default(false)
  tenantId  String?   @db.Uuid
  createdAt DateTime? @default(now()) @db.Timestamptz(6)
  updatedAt DateTime? @default(now()) @updatedAt @db.Timestamptz(6)

  tenant          Tenant?           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  terms           Term[]
  classes         AcademicClass[]
  timetables      Timetable[]
  feeStructures   FeeStructure[]
  SiblingDiscount SiblingDiscount[]

  @@unique([tenantId, name], map: "academic_years_tenantId_name_unique")
  @@index([tenantId], map: "idx_academic_years_tenant")
  @@map("academic_years")
}

model Term {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String
  startDate      DateTime  @db.Timestamptz(6)
  endDate        DateTime  @db.Timestamptz(6)
  isCurrent      Boolean?  @default(false)
  academicYearId String?   @db.Uuid
  createdAt      DateTime? @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime? @default(now()) @updatedAt @db.Timestamptz(6)

  academicYear  AcademicYear?  @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  exams         Exam[]
  reportCards   ReportCard[]
  feeStructures FeeStructure[]

  @@unique([academicYearId, name], map: "terms_academicYearId_name_unique")
  @@index([academicYearId], map: "idx_terms_academic_year")
  @@map("terms")
}

model AcademicClass {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String
  level          Int
  capacity       Int?      @default(40)
  academicYearId String?   @db.Uuid
  tierId         String?   @db.Uuid
  departmentId   String?   @db.Uuid
  createdAt      DateTime? @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime? @default(now()) @updatedAt @db.Timestamptz(6)

  academicYear   AcademicYear?   @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  tier           Tier?           @relation(fields: [tierId], references: [id])
  department     Department?      @relation(fields: [departmentId], references: [id])
  subjects       Subject[]
  enrollments    Enrollment[]
  timetableSlots TimetableSlot[]
  attendances    Attendance[]

  @@unique([academicYearId, name], map: "academic_classes_academicYearId_name_unique")
  @@index([academicYearId], map: "idx_academic_classes_academic_year")
  @@index([tierId], map: "idx_academic_classes_tier")
  @@map("academic_classes")
}

model Subject {
  id              String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String
  code            String
  academicClassId String?     @db.Uuid
  teacherId       String?     @db.Uuid
  departmentId    String?     @db.Uuid
  curriculum      Curriculum  @default(NERDC)
  isActive        Boolean     @default(true)
  createdAt       DateTime?   @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime?   @default(now()) @db.Timestamptz(6)

  academicClass  AcademicClass?  @relation(fields: [academicClassId], references: [id], onDelete: Cascade)
  teacher        Teacher?        @relation(fields: [teacherId], references: [id])
  department     Department?    @relation(fields: [departmentId], references: [id])
  exams          Exam[]
  timetableSlots TimetableSlot[]

  @@unique([academicClassId, code], map: "subjects_academicClassId_code_unique")
  @@index([academicClassId], map: "idx_subjects_academic_class")
  @@index([departmentId], map: "idx_subjects_department")
  @@map("subjects")
}

// ==================== CURRICULUM ENUM ====================
enum Curriculum {
  NERDC
  CAMBRIDGE
  AMERICAN
  IB
}

// ==================== TIER (School Levels) ====================
model Tier {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  code        String   // CRE, PRE_NUR, NUR, PRI, JSS, SSS
  alias       String?  // Optional custom name (e.g., "Lower School")
  order       Int
  isActive    Boolean  @default(true)
  tenantId    String   @db.Uuid
  createdAt   DateTime @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  tenant       Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  classes      AcademicClass[]
  departments  Department[]
  tierCurriculum TierCurriculum?
  badges       Badge[]

  @@unique([tenantId, code], map: "tiers_tenantId_code_unique")
  @@index([tenantId], map: "idx_tiers_tenant")
  @@map("tiers")
}

// ==================== DEPARTMENT (SSS Streams) ====================
model Department {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  code      String   // SCI, COM, ART, TEC
  alias     String?  // Optional custom name
  isActive  Boolean  @default(true)
  tierId    String   @db.Uuid
  tenantId  String   @db.Uuid
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  tier      Tier           @relation(fields: [tierId], references: [id], onDelete: Cascade)
  tenant    Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  classes   AcademicClass[]
  subjects  Subject[]

  @@unique([tenantId, code], map: "departments_tenantId_code_unique")
  @@index([tenantId], map: "idx_departments_tenant")
  @@index([tierId], map: "idx_departments_tier")
  @@map("departments")
}

// ==================== TIER CURRICULUM ====================
model TierCurriculum {
  id         String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tierId     String     @unique @db.Uuid
  curriculum Curriculum
  tenantId   String     @db.Uuid
  createdAt  DateTime   @default(now()) @db.Timestamptz(6)
  updatedAt  DateTime   @default(now()) @updatedAt @db.Timestamptz(6)

  tier   Tier   @relation(fields: [tierId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId], map: "idx_tier_curriculum_tenant")
  @@map("tier_curriculum")
}

// ==================== TENANT SETTINGS ====================
model TenantSettings {
  id                     String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId               String     @unique @db.Uuid
  curriculumType         Curriculum @default(NERDC)
  usePerTierCurriculum   Boolean    @default(false)
  tiersSetupComplete     Boolean    @default(false)
  badgesEnabled          Boolean    @default(true)
  badgesAutoAward        Boolean    @default(false) // true = auto, false = manual approval
  badgesShowOnReport     Boolean    @default(true)
  daysPerWeek            Int        @default(5) // 5 = Mon-Fri, 6 = Mon-Sat
  periodDuration         Int        @default(40) // in minutes
  createdAt              DateTime   @default(now()) @db.Timestamptz(6)
  updatedAt              DateTime   @updatedAt @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_settings")
}

// ==================== LMS: Courses ====================
model Course {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  code        String
  description String?
  creditHours Int      @default(3)
  tenantId    String   @db.Uuid
  teacherId   String   @db.Uuid
  createdAt   DateTime @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  tenant          Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lessons         Lesson[]
  assignments     Assignment[]
  DiscussionForum DiscussionForum[]

  @@unique([tenantId, code], map: "courses_tenantId_code_unique")
  @@index([tenantId], map: "idx_courses_tenant")
  @@map("courses")
}

// ==================== LMS: Lessons ====================
model Lesson {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String
  content     Json      @default("{}")
  type        String    @default("ARTICLE")
  duration    Int?
  order       Int       @default(0)
  isPublished Boolean   @default(false)
  isFree      Boolean   @default(false)
  publishAt   DateTime? @db.Timestamptz(6)
  courseId    String    @db.Uuid
  subjectId   String?   @db.Uuid
  createdById String?   @db.Uuid
  createdAt   DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime  @default(now()) @updatedAt @db.Timestamptz(6)

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId], map: "idx_lessons_course")
  @@map("lessons")
}

model LessonProgress {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studentId   String    @db.Uuid
  lessonId    String    @db.Uuid
  progress    Float     @default(0)
  completedAt DateTime? @db.Timestamptz(6)
  timeSpent   Int?
  createdAt   DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime  @default(now()) @updatedAt @db.Timestamptz(6)

  @@unique([studentId, lessonId], map: "lesson_progress_unique")
  @@index([lessonId], map: "idx_lesson_progress_lesson")
  @@map("lesson_progress")
}

// ==================== LMS: Assignments ====================
model Assignment {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title           String
  description     String?
  instructions    String?
  type            String    @default("INDIVIDUAL")
  points          Int       @default(100)
  dueDate         DateTime? @db.Timestamptz(6)
  allowLate       Boolean   @default(true)
  latePenalty     Float?
  isPublished     Boolean   @default(false)
  allowFileUpload Boolean   @default(true)
  maxFileSize     Int?
  courseId        String    @db.Uuid
  subjectId       String?   @db.Uuid
  classId         String?   @db.Uuid
  createdById     String?   @db.Uuid
  createdAt       DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime  @default(now()) @updatedAt @db.Timestamptz(6)

  course               Course                 @relation(fields: [courseId], references: [id], onDelete: Cascade)
  AssignmentSubmission AssignmentSubmission[]

  @@index([courseId], map: "idx_assignments_course")
  @@index([dueDate], map: "idx_assignments_due")
  @@map("assignments")
}

model AssignmentSubmission {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  content      String?
  fileUrl      String?
  status       String    @default("SUBMITTED")
  grade        Float?
  feedback     String?
  gradedAt     DateTime? @db.Timestamptz(6)
  submittedAt  DateTime? @db.Timestamptz(6)
  assignmentId String    @db.Uuid
  studentId    String    @db.Uuid
  tenantId     String    @db.Uuid
  createdAt    DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime  @default(now()) @updatedAt @db.Timestamptz(6)

  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, studentId], map: "assignment_submissions_unique")
  @@index([assignmentId], map: "idx_assignment_submissions_assignment")
  @@index([studentId], map: "idx_assignment_submissions_student")
  @@map("assignment_submissions")
