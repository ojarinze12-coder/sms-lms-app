// ==================== SMS: Admissions ====================
model Application {
  id            String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  applicationNo String

  // Personal info
  firstName   String
  lastName    String
  middleName  String?
  dateOfBirth DateTime? @db.Date
  gender      String?
  phone       String
  email       String?
  address     String?

  // Nigerian specific
  stateOfOrigin String?
  lgaOfOrigin   String?
  birthCertNo   String?

  // Previous school
  previousSchool String?
  previousClass  String?
  transferCert   String?

  // JAMB/WAEC (for SS3 applicants)
  jambRegNo String?
  waecNo    String?

  // Guardian/Parent info
  guardianName     String?
  guardianPhone    String?
  guardianEmail    String?
  guardianRelation String?
  guardianAddress  String?

  // Documents (stored as JSON URLs)
  documents Json? // { birthCertificate: url, idCard: url, ... }

  // Application details
  applyingClassId String? @db.Uuid
  academicYearId  String? @db.Uuid

  // Status tracking
  status            String  @default("PENDING") // PENDING, REVIEWING, ENTRANCE_EXAM, INTERVIEW, APPROVED, REJECTED, ENROLLED, WITHDRAWN
  entranceExamScore Float?
  interviewScore    Float?
  notes             String?

  // Assigned student (when enrolled)
  enrolledStudentId String? @db.Uuid

  tenantId  String   @db.Uuid
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, applicationNo], map: "applications_tenantId_applicationNo_unique")
  @@index([tenantId], map: "idx_applications_tenant")
  @@index([status], map: "idx_applications_status")
  @@map("applications")
}

// ==================== SMS: Timetable ====================
model Timetable {
