// ==================== BILLING ====================
model Invoice {
  id        String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  amount    Float
  status    InvoiceStatus @default(PENDING)
  dueDate   DateTime
  paidAt    DateTime?
  tenantId  String        @db.Uuid
  createdAt DateTime      @default(now()) @db.Timestamptz(6)
  updatedAt DateTime      @default(now()) @updatedAt @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId], map: "idx_invoices_tenant")
  @@map("invoices")
}

enum InvoiceStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

model Subscription {
  id     String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  planId String?           @db.Uuid
  plan   SubscriptionPlan? @relation(fields: [planId], references: [id])

  status               String?   @default("ACTIVE")
  tenantId             String?   @unique @db.Uuid
  stripeCustomerId     String?
  stripeSubscriptionId String?
  currentPeriodStart   DateTime? @db.Timestamptz(6)
  currentPeriodEnd     DateTime? @db.Timestamptz(6)
  features             Json?     @default("{}")

  billingCycle     BillingCycle @default(MONTHLY)
  nextBillingDate  DateTime?    @db.Timestamptz(6)
  cancellationDate DateTime?    @db.Timestamptz(6)

  paymentMethod String?
  last4         String?
  cardBrand     String?

  failedPaymentsCount Int       @default(0)
  gracePeriodEnds     DateTime? @db.Timestamptz(6)
  isLocked            Boolean   @default(false)

  createdAt DateTime? @default(now()) @db.Timestamptz(6)
  updatedAt DateTime? @default(now()) @updatedAt @db.Timestamptz(6)

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  subscriptionInvoices SubscriptionInvoice[]

  @@map("subscriptions")
}

// ==================== SUBSCRIPTION INVOICING (PCC Platform Billing) ====================
model SubscriptionInvoice {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  invoiceNumber   String           @unique
  tenantId        String           @db.Uuid
  subscriptionId String?          @db.Uuid
  planId          String           @db.Uuid

  amount          Float
  currency        String           @default("NGN")
  status          InvoiceStatus    @default(PENDING)
  dueDate         DateTime         @db.Date
  paidAt          DateTime?        @db.Timestamptz(6)

  billingPeriodStart DateTime      @db.Timestamptz(6)
  billingPeriodEnd   DateTime      @db.Timestamptz(6)
  billingCycle       BillingCycle

  description     String?
  notes           String?

  tenant        Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscription  Subscription?        @relation(fields: [subscriptionId], references: [id])
  plan          SubscriptionPlan     @relation(fields: [planId], references: [id])
  payments      SubscriptionPayment[]

  createdAt     DateTime @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  @@index([tenantId], map: "idx_sub_invoices_tenant")
  @@index([status], map: "idx_sub_invoices_status")
  @@map("subscription_invoices")
}

model SubscriptionPayment {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  invoiceId       String        @db.Uuid
  amount          Float
  currency        String        @default("NGN")
  status          PaymentStatus @default(PENDING)
  method          String        @default("ONLINE")
  referenceNo    String?       @unique
  transactionId   String?
  paymentGateway  String        // PAYSTACK, FLUTTERWAVE
  gatewayResponse Json?
  paidAt          DateTime?     @db.Timestamptz(6)
  receiptUrl      String?
  receiptNumber   String?

  invoice SubscriptionInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  @@index([invoiceId], map: "idx_sub_payments_invoice")
  @@index([referenceNo], map: "idx_sub_payments_reference")
  @@map("subscription_payments")
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

