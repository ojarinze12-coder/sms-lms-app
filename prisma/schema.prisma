generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Tenant {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String
  slug       String   @unique
  domain     String?
  status     String   @default("ACTIVE")
  brandColor String   @default("#1a56db")
  logo       String?
  config     Json     @default("{}")
  createdAt  DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @db.Timestamptz(6)
  plan       String   @default("FREE")
  ownerId    String?  @db.Uuid  // Groups multiple schools under one owner
  users      User[]
  courses    Course[]
  supportTickets SupportTicket[]
  messageCampaigns MessageCampaign[]
  ptaNotices PtaNotice[]
  conversations Conversation[]
  hostels    Hostel[]
  documents  Document[]
  documentCategories DocumentCategory[]
  subscriptions Subscription[]
  announcements Announcement[]
  branches   Branch[]
  
  @@index([ownerId], map: "idx_tenants_owner")
  @@map("tenants")
}

model Branch {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name     String
  code     String   // "MAIN", "CAMPUS-A", "CAMPUS-B", etc.
  address  String?
  phone   String?
  email   String?
  isActive Boolean  @default(true)
  isMain   Boolean  @default(false)
  tenantId String   @db.Uuid
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @db.Timestamptz(6)
  
  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  students Student[]
  teachers Teacher[]
  staff    Staff[]
  classes  AcademicClass[]
  enrollments Enrollment[]
  attendances Attendance[]
  feePayments FeePayment[]
  results    Result[]
  timetableSlots TimetableSlot[]
  feeStructures FeeStructure[]
  tiers    Tier[]
  departments Department[]
  academicYears AcademicYear[]
  
  @@unique([tenantId, code], map: "branches_tenantId_code_unique")
  @@index([tenantId], map: "idx_branches_tenant")
  @@map("branches")
}

model User {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email               String    @unique
  password            String?
  firstName           String?
  lastName            String?
  role                UserRole  @default(TEACHER)
  tenantId            String?   @db.Uuid
  tokenVersion        Int       @default(1)
  twoFactorSecret     String?
  twoFactorBackupCodes String?
  twoFactorEnabled    Boolean   @default(false)
  lastLoginAt         DateTime? @db.Timestamptz(6)
  lastLoginIp         String?
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime? @db.Timestamptz(6)
  allowedIps          String?
  isActive            Boolean   @default(true)
  createdAt           DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt           DateTime  @default(now()) @updatedAt @db.Timestamptz(6)
  tenant              Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reportGenerations  ReportGeneration[]

  @@index([tenantId])
  @@map("users")
}

model Student {
  id                  String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studentId           String
  email               String?
  firstName           String
  lastName            String
  middleName          String?
  dateOfBirth         DateTime?            @db.Date
  gender              Gender?
  phone               String?
  address             String?
  stateOfOrigin       String?
  lgaOfOrigin         String?
  birthCertNo         String?
  jambRegNo           String?
  bloodGroup          String?
  genotype            String?
  allergies           String?
  medicalConditions   String?
  emergencyContact    String?
  emergencyPhone      String?
  photo               String?
  status              StudentStatus        @default(ACTIVE)
  tenantId            String               @db.Uuid
  branchId            String?              @db.Uuid
  createdAt           DateTime             @default(now()) @db.Timestamptz(6)
  updatedAt           DateTime             @default(now()) @updatedAt @db.Timestamptz(6)
  barcode             String?
  biometricId         String?
  cardExpiresAt       DateTime?            @db.Date
  cardIssuedAt        DateTime?            @db.Timestamptz(6)
  cardStatus          String               @default("NOT_ISSUED")
  qrCodeData          String?
  attendances         Attendance[]
  enrollments         Enrollment[]
  feePayments         FeePayment[]
  libraryCirculations LibraryCirculation[]
  parentStudents      ParentStudent[]
  parents             Parent[]
  results             Result[]
  studentBadges       StudentBadge[]
  studentCertificates StudentCertificate[]
  reportCards        ReportCard[]
  behaviorIncidents  BehaviorIncident[]
  behaviorLogs       BehaviorLog[]
  medicalRecords     StudentMedicalRecord[]
  transcripts        Transcript[]
  certificateIssuances CertificateIssuance[]
  hostelAllocations  HostelAllocation[]
  vaccinations       StudentVaccination[]
  transportSubscriptions TransportSubscription[]
  documents           Document[]
  branch              Branch?             @relation(fields: [branchId], references: [id])

  @@unique([tenantId, studentId], map: "students_tenantId_studentId_unique")
  @@index([tenantId], map: "idx_students_tenant")
  @@index([stateOfOrigin], map: "idx_students_state")
  @@index([tenantId])
  @@index([branchId], map: "idx_students_branch")
  @@map("students")
}

model Teacher {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId     String
  email          String
  firstName      String
  lastName       String
  specialty      String?
  phone          String?
  tenantId       String       @db.Uuid
  branchId       String?      @db.Uuid
  createdAt      DateTime     @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime     @default(now()) @updatedAt @db.Timestamptz(6)
  address        String?
  bankAccount    String?
  bankName       String?
  bankSortCode   String?
  bvn            String?
  dateOfBirth    DateTime?    @db.Date
  department     String?
  employmentType String?
  experience     Int?
  gender         String?
  joinDate       DateTime?    @db.Date
  lgaOfOrigin    String?
  nhfNumber      String?
  pensionPin     String?
  position       String?      // "HOD", "SENIOR_TEACHER", "FORM_MASTER", "CLASS_TEACHER"
  departmentId   String?      @db.Uuid @map("department_id")  // For HOD - links to Department
  qualification  String?
  salary         Float?
  stateOfOrigin  String?
  status         String       @default("ACTIVE")
  barcode        String?
  biometricId    String?
  cardExpiresAt  DateTime?    @db.Date
  cardIssuedAt   DateTime?    @db.Timestamptz(6)
  cardStatus     String       @default("NOT_ISSUED")
  qrCodeData     String?
  payrolls       Payroll[]
  staffLeaves    StaffLeave[]
  subjects       Subject[]
  courses        Course[]
  departmentRelation Department?  @relation("TeacherDepartments", fields: [departmentId], references: [id])
  classTeacherClasses AcademicClass[] @relation("ClassTeacherClasses")
  formMasterClasses AcademicClass[] @relation("FormMasterClasses")
  branch        Branch?      @relation(fields: [branchId], references: [id])

  @@unique([tenantId, employeeId], map: "teachers_tenantId_employeeId_unique")
  @@index([tenantId], map: "idx_teachers_tenant")
  @@index([tenantId])
  @@index([branchId], map: "idx_teachers_branch")
  @@map("teachers")
}

model Staff {
  id             String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId     String
  email          String
  firstName      String
  lastName       String
  category       StaffCategory       @default(OTHER)
  phone          String?
  dateOfBirth    DateTime?           @db.Date
  gender         String?
  address        String?
  stateOfOrigin  String?
  lgaOfOrigin    String?
  photo          String?
  qualification  String?
  experience     Int?
  joinDate       DateTime?           @db.Date
  employmentType StaffEmploymentType @default(FULL_TIME)
  department     String?
  position       String?
  salary         Float?
  pensionPin     String?
  nhfNumber      String?
  bvn            String?
  bankName       String?
  bankAccount    String?
  bankSortCode   String?
  status         String              @default("ACTIVE")
  tenantId       String              @db.Uuid
  branchId       String?            @db.Uuid
  createdAt      DateTime            @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime            @default(now()) @updatedAt @db.Timestamptz(6)
  barcode        String?
  biometricId    String?
  cardExpiresAt  DateTime?           @db.Date
  cardIssuedAt   DateTime?           @db.Timestamptz(6)
  cardStatus     String              @default("NOT_ISSUED")
  qrCodeData     String?
  staffLeaves    StaffLeave[]
  caregiverClasses AcademicClass[] @relation("CaregiverClasses")
  branch        Branch?            @relation(fields: [branchId], references: [id])

  @@unique([tenantId, employeeId], map: "staff_tenantId_employeeId_unique")
  @@index([tenantId], map: "idx_staff_tenant")
  @@index([tenantId, category], map: "idx_staff_category")
  @@index([branchId], map: "idx_staff_branch")
  @@map("staff")
}

model Payroll {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  month              Int
  year               Int
  basicSalary        Float
  housingAllowance   Float?
  transportAllowance Float?
  otherAllowances    Float?
  totalEarnings      Float?
  pensionDeduction   Float?
  taxDeduction       Float?
  nhfDeduction       Float?
  otherDeductions    Float?
  totalDeductions    Float?
  netPay             Float?
  status             String    @default("DRAFT")
  paymentDate        DateTime? @db.Timestamptz(6)
  paymentReference   String?
  teacherId          String    @db.Uuid
  tenantId           String    @db.Uuid
  createdAt          DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt          DateTime  @default(now()) @updatedAt @db.Timestamptz(6)
  teacher            Teacher   @relation(fields: [teacherId], references: [id])

  @@unique([teacherId, month, year], map: "payroll_teacher_month_year_unique")
  @@index([tenantId, year, month], map: "payroll_tenant_year_month")
  @@map("payrolls")
}

model Parent {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  firstName        String
  lastName         String
  email            String?
  phone            String?
  occupation       String?
  tenantId         String?            @db.Uuid
  studentId        String?            @db.Uuid
  createdAt        DateTime?          @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime?          @default(now()) @updatedAt @db.Timestamptz(6)
  approvalStatus   ApprovalStatus     @default(PENDING)
  isPrimaryContact Boolean            @default(false)
  relationship     ParentRelationship @default(GUARDIAN)
  userId           String?            @db.Uuid
  workplace        String?
  parentStudents   ParentStudent[]
  Student          Student?           @relation(fields: [studentId], references: [id])

  @@map("parents")
}

model ParentStudent {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  parentId         String             @db.Uuid
  studentId        String             @db.Uuid
  relationship     ParentRelationship @default(GUARDIAN)
  isPrimaryContact Boolean            @default(false)
  approvalStatus   ApprovalStatus     @default(PENDING)
  approvedBy       String?            @db.Uuid
  approvedAt       DateTime?          @db.Timestamptz(6)
  createdAt        DateTime?          @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime?          @default(now()) @updatedAt @db.Timestamptz(6)
  tenantId         String?            @db.Uuid
  parent           Parent             @relation(fields: [parentId], references: [id], onDelete: Cascade)
  student          Student            @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([parentId, studentId], map: "parent_student_unique")
  @@index([parentId], map: "idx_parent_student_parent")
  @@index([studentId], map: "idx_parent_student_student")
  @@map("parent_students")
}

model SiblingDiscount {
  id                  String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId            String        @db.Uuid
  academicYearId      String?       @db.Uuid
  linkingMode         LinkingMode   @default(ADMIN_APPROVAL)
  discountType        String        @default("PERCENTAGE")
  secondChildDiscount Float         @default(0)
  thirdChildDiscount  Float         @default(0)
  fourthChildDiscount Float         @default(0)
  fifthChildDiscount  Float         @default(0)
  isActive            Boolean       @default(true)
  createdAt           DateTime      @default(now()) @db.Timestamptz(6)
  updatedAt           DateTime      @default(now()) @updatedAt @db.Timestamptz(6)
  academicYear        AcademicYear? @relation(fields: [academicYearId], references: [id])

  @@unique([tenantId, academicYearId], map: "sibling_discount_unique")
  @@map("sibling_discounts")
}

model AcademicYear {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String
  startDate       DateTime          @db.Timestamptz(6)
  endDate         DateTime          @db.Timestamptz(6)
  isActive        Boolean?          @default(false)
  tenantId        String?           @db.Uuid
  branchId        String?           @db.Uuid
  createdAt       DateTime?         @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime?         @default(now()) @updatedAt @db.Timestamptz(6)
  classes         AcademicClass[]
  feeStructures   FeeStructure[]
  SiblingDiscount SiblingDiscount[]
  terms           Term[]
  timetables      Timetable[]
  transcripts     Transcript[]
  certificateIssuances CertificateIssuance[]
  applications    Application[]
  transportSubscriptions TransportSubscription[]
  hostelAllocations HostelAllocation[]
  branch          Branch?           @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@unique([tenantId, name], map: "academic_years_tenantId_name_unique")
  @@index([tenantId], map: "idx_academic_years_tenant")
  @@index([branchId], map: "idx_academic_years_branch")
  @@map("academic_years")
}

model Term {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String
  startDate      DateTime       @db.Timestamptz(6)
  endDate        DateTime       @db.Timestamptz(6)
  isCurrent      Boolean?       @default(false)
  academicYearId String?        @db.Uuid
  createdAt      DateTime?      @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime?      @default(now()) @updatedAt @db.Timestamptz(6)
  exams          Exam[]
  feeStructures  FeeStructure[]
  reportCards    ReportCard[]
  academicYear   AcademicYear?  @relation(fields: [academicYearId], references: [id], onDelete: Cascade)

  @@unique([academicYearId, name], map: "terms_academicYearId_name_unique")
  @@index([academicYearId], map: "idx_terms_academic_year")
  @@map("terms")
}

model AcademicClass {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String
  level          Int
  capacity       Int?            @default(40)
  stream         String?         // Stream identifier: "A", "B", "C", "D" or "SCI", "COMM", "ARTS", "TECH" etc.
  classTeacherId String?         @db.Uuid @map("class_teacher_id")  // Class Teacher (Pre-Nursery, Nursery, Primary)
  formMasterId   String?         @db.Uuid @map("form_master_id")  // Secondary Form Master (JSS, SSS)
  caregiverId    String?         @db.Uuid @map("caregiver_id")  // Pre-Nursery/Nursery Care-giver
  academicYearId String?         @db.Uuid
  tenantId       String?         @db.Uuid
  branchId       String?         @db.Uuid
  createdAt      DateTime?       @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime?       @default(now()) @updatedAt @db.Timestamptz(6)
  departmentId   String?         @db.Uuid
  tierId         String?         @db.Uuid
  department     Department?     @relation(fields: [departmentId], references: [id])
  academicYear   AcademicYear?   @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  attendances    Attendance[]
  enrollments    Enrollment[]
  subjects       Subject[]
  timetableSlots TimetableSlot[]
  transcripts    Transcript[]
  applications  Application[]
  classTeacher  Teacher?        @relation("ClassTeacherClasses", fields: [classTeacherId], references: [id])
  formMaster    Teacher?        @relation("FormMasterClasses", fields: [formMasterId], references: [id])
  caregiver     Staff?          @relation("CaregiverClasses", fields: [caregiverId], references: [id])
  branch        Branch?        @relation(fields: [branchId], references: [id])
  tier          Tier?          @relation(fields: [tierId], references: [id])

  @@unique([academicYearId, name, stream], map: "academic_classes_academicYearId_name_stream_unique")
  @@index([academicYearId], map: "idx_academic_classes_academic_year")
  @@index([tierId], map: "idx_academic_classes_tier")
  @@index([tenantId], map: "idx_academic_classes_tenant")
  @@index([departmentId], map: "idx_academic_classes_department")
  @@index([branchId], map: "idx_academic_classes_branch")
  @@map("academic_classes")
}

model Subject {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String
  code            String
  academicClassId String?         @db.Uuid
  teacherId       String?         @db.Uuid
  tenantId        String?         @db.Uuid
  createdAt       DateTime?       @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime?       @default(now()) @db.Timestamptz(6)
  curriculum      Curriculum      @default(NERDC)
  departmentId    String?         @db.Uuid
  isActive        Boolean         @default(true)
  exams           Exam[]
  academicClass   AcademicClass?  @relation(fields: [academicClassId], references: [id], onDelete: Cascade)
  teacher         Teacher?        @relation(fields: [teacherId], references: [id])
  timetableSlots  TimetableSlot[]

  @@unique([academicClassId, code], map: "subjects_academicClassId_code_unique")
  @@index([academicClassId], map: "idx_subjects_academic_class")
  @@index([tenantId], map: "idx_subjects_tenant")
  @@index([departmentId], map: "idx_subjects_department")
  @@map("subjects")
}

model Tier {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String    @db.VarChar(255)
  code      String    @db.VarChar(10)
  alias     String?   @db.VarChar(255)
  order     Int
  isActive  Boolean?  @default(true)
  tenantId  String    @db.Uuid
  branchId  String?   @db.Uuid
  createdAt DateTime? @default(now()) @db.Timestamptz(6)
  updatedAt DateTime? @default(now()) @updatedAt @db.Timestamptz(6)
  badges    Badge[]
  classes      AcademicClass[]
  departments Department[]
  tierCurriculum TierCurriculum?
  feeStructures FeeStructure[]
  branch    Branch?   @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@unique([tenantId, code], map: "tiers_tenantId_code_unique")
  @@index([tenantId], map: "idx_tiers_tenant")
  @@index([branchId], map: "idx_tiers_branch")
  @@map("tiers")
}

model Department {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  code      String
  alias     String?
  isActive  Boolean  @default(true)
  tierId    String   @db.Uuid
  tenantId  String   @db.Uuid
  branchId  String?  @db.Uuid
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  tier            Tier            @relation(fields: [tierId], references: [id], onDelete: Cascade)
  academicClasses AcademicClass[]
  teachers        Teacher[]       @relation("TeacherDepartments")
  branch          Branch?         @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@unique([tenantId, code], map: "departments_tenantId_code_unique")
  @@index([tenantId], map: "idx_departments_tenant")
  @@index([tierId], map: "idx_departments_tier")
  @@index([branchId], map: "idx_departments_branch")
  @@map("departments")
}

model TierCurriculum {
  id         String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tierId     String     @unique @db.Uuid
  curriculum Curriculum @default(NERDC)
  tenantId   String     @db.Uuid
  createdAt  DateTime?  @default(now()) @db.Timestamptz(6)
  updatedAt  DateTime?  @default(now()) @updatedAt @db.Timestamptz(6)

  tier        Tier       @relation(fields: [tierId], references: [id])

  @@index([tenantId], map: "idx_tier_curriculum_tenant")
  @@map("tier_curriculum")
}

model TenantSettings {
  id                          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId                    String     @unique @db.Uuid
  curriculumType              Curriculum @default(NERDC)
  usePerTierCurriculum        Boolean    @default(false)
  tiersSetupComplete          Boolean    @default(false)
  createdAt                   DateTime   @default(now()) @db.Timestamptz(6)
  updatedAt                   DateTime   @updatedAt @db.Timestamptz(6)
  badgesEnabled               Boolean    @default(true)
  badgesAutoAward             Boolean    @default(false)
  badgesShowOnReport          Boolean    @default(true)
  daysPerWeek                 Int        @default(5)
  periodDuration              Int        @default(40)
  allowParentRegistration     Boolean    @default(true)
  applicationDeadline         DateTime?  @db.Date
  applicationFee              Float?     @default(0)
  applicationPaymentGateway   String?
  applicationsEnabled         Boolean    @default(false)
  auditAlertsEnabled          Boolean    @default(false)
  auditCategories             String[]   @default(["STUDENT", "ACADEMIC", "ATTENDANCE", "FEE", "ENROLLMENT"])
  auditEnabled                Boolean    @default(true)
  auditExportEnabled          Boolean    @default(true)
  auditLogLevel               String     @default("STANDARD")
  auditRetentionDays          Int        @default(90)
  auditSensitiveActions       String[]   @default(["SUSPENSION", "GRADE_CHANGE", "REFUND", "TERMINATION"])
  autoEnrollClasses           String[]   @default([])
  documentAllowedTypes        String[]   @default(["image/jpeg", "image/png", "application/pdf"])
  documentAutoExpiry          Boolean    @default(true)
  documentExpiryDays          Int        @default(30)
  documentMaxSize             Int        @default(5)
  documentRequireVerification Boolean    @default(false)
  documentStorageType         String     @default("LOCAL")
  documentsEnabled            Boolean    @default(false)
  entranceExamThreshold       Float      @default(50)
  hostelAutoAssign            Boolean    @default(true)
  hostelChargeFee             Boolean    @default(false)
  hostelCheckInOut            Boolean    @default(true)
  hostelDefaultCapacity       Int        @default(4)
  hostelDefaultRoomType       String     @default("DORMITORY")
  hostelEnabled               Boolean    @default(false)
  hostelRequireApproval       Boolean    @default(false)
  hostelTypesAllowed          String[]   @default(["MALE", "FEMALE"])
  requireDocuments            Boolean    @default(false)
  requireEntranceExam         Boolean    @default(false)
  requireInterview            Boolean    @default(false)
  requiredDocumentTypes       String[]   @default([])
  sendWelcomeEmail            Boolean    @default(true)
  transportAllowPartial       Boolean    @default(false)
  transportDailyAttendance    Boolean    @default(false)
  transportFreeTransport      Boolean    @default(false)
  transportNotifications      String[]   @default([])
  transportPaymentModel       String     @default("TERM")
  bulkEmailEnabled            Boolean    @default(true)
  bulkSmsEnabled              Boolean    @default(true)
  bulkWhatsappEnabled         Boolean    @default(true)
  chatEnabled                 Boolean    @default(true)
  communicationEnabled        Boolean    @default(true)
  customReportsEnabled        Boolean    @default(true)
  defaultMessageChannel       String     @default("SMS")
  jitsiDomain                 String     @default("meet.jit.si")
  ptaNoticesEnabled           Boolean    @default(true)
  regulatoryReportsEnabled    Boolean    @default(true)
  reportsEnabled              Boolean    @default(true)
  virtualClassEnabled        Boolean    @default(true)
  themeMode                  String     @default("SYSTEM") // LIGHT, DARK, SYSTEM
  enableClassSections        Boolean    @default(false)
  defaultSectionNaming       String     @default("A,B,C")
  sectionsPerClass           Int        @default(2)

  // Payment Gateway Configuration (School Fees)
  paymentGatewayEnabled      Boolean    @default(false)
  paymentGateway             String?    // 'PAYSTACK', 'FLUTTERWAVE'
  paymentGatewaySecretKey    String?    // Encrypted
