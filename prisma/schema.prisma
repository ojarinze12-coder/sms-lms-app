  academicYear AcademicYear?   @relation(fields: [academicYearId], references: [id])
  slots        TimetableSlot[]

  @@unique([academicYearId, name], map: "timetables_academicYearId_name_unique")
  @@index([academicYearId], map: "idx_timetables_academic_year")
