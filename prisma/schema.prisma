// ==================== LMS: Discussion Forums ====================
model DiscussionForum {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String
  description String?
  type        String   @default("GENERAL") // GENERAL, Q_A, ANNOUNCEMENTS
  isPublished Boolean  @default(true)
  courseId    String   @db.Uuid
  createdById String?  @db.Uuid
  createdAt   DateTime @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  course Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  posts  DiscussionPost[]

  @@index([courseId], map: "idx_discussion_forums_course")
  @@map("discussion_forums")
}

model DiscussionPost {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  content   String
  isPinned  Boolean  @default(false)
  isAnswer  Boolean  @default(false)
  upvotes   Int      @default(0)
  downvotes Int      @default(0)
  parentId  String?  @db.Uuid
  forumId   String   @db.Uuid
  userId    String?  @db.Uuid
  tenantId  String?  @db.Uuid
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  forum   DiscussionForum  @relation(fields: [forumId], references: [id], onDelete: Cascade)
  parent  DiscussionPost?  @relation("PostReplies", fields: [parentId], references: [id])
  replies DiscussionPost[] @relation("PostReplies")

  @@index([forumId], map: "idx_discussion_posts_forum")
  @@index([parentId], map: "idx_discussion_posts_parent")
  @@map("discussion_posts")
}
